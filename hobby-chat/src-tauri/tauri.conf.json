{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HobbyLM Chat",
  "version": "0.1.0",
  "identifier": "com.hobbylm.chat",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "HobbyLM Chat — local 500M MoE",
        "width": 940,
        "height": 780,
        "minWidth": 560,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
